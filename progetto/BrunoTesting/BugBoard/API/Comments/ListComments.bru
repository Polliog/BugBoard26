meta {
  name: List Comments
  type: http
  seq: 2
}

get {
  url: {{baseURL}}/api/issues/{{issueId}}/comments
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("should return list of comments", function() {
    expect(res.body).to.be.an("array");
    expect(res.body.length).to.be.greaterThan(0);
  });
}
